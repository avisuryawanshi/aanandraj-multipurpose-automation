<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  ========================================
  TestNG Suite: Regression Group Execution
  ========================================

  💡 Purpose:
  This suite file filters and executes only those test methods that are
  annotated with: @Test(groups = {"regression"})

  🔧 How to Use:
  - Use this suite during regression cycles.
  - Helps isolate and execute critical flow validations.
-->
<suite name="grouping suite">
  
  <test name="grouping test">

      <!--
      ==========================
      Group Filtering Mechanism
      ==========================
      ✅ Only run test methods with group name: regression
      ❌ All other methods (without this group) will be ignored
    -->
     <groups>
		<run>
			<include name="regression"/>
		</run>
	 </groups>

      <!--
     ========================================
     Classes involved in group-filtered tests
     ========================================
     Note:
     Only test methods with @Test(groups = {"regression"}) will run,
     even if other methods exist in these classes.
   -->
      <classes>
          <!-- 🔹 Individual Test Cases ===================================== -->
          <class name="testCases.M01_LoginTests"/>
          <class name="testCases.M02_HomeTests"/>
          <class name="testCases.M03_BookingWorkflowTests"/>
          <class name="testCases.M03_SearchingTests"/>
          <class name="testCases.M03_OverflowMenuTest"/>
          <class name="testCases.M03_DashboardTest"/>
          <class name="testCases.M01_BiometricTests"/>
          <class name="testCases.M01_LoginRandomTest"/>
          <class name="testCases.TC009LoginLoggerTest"/>
          <!-- 🔸 Grouped Test Cases ======================================== -->
    <!--  <class name="testGrouping.GP001LoginTest"/>
          <class name="testGrouping.GP002HomeTest"/>
          <class name="testGrouping.GP003BookingTest"/>
          <class name="testGrouping.GP004SearchingTest"/>
          <class name="testGrouping.GP005OverflowMenuTest"/>
          <class name="testGrouping.GP006DashboardTest"/> -->
     </classes>

</test> <!-- Test -->
  
</suite> <!-- Suite -->