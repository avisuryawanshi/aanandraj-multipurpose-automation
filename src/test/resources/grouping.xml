<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  ===========================
  Master Suite Configuration
  ===========================

  👇 Purpose:
  - Run grouped tests selectively (e.g., Sanity, Master, Regression).
  - Useful for CI pipelines or custom test runs.

  ✅ Current Grouping Strategy:
  - Running only: "Sanity" and "Master" groups.
  - Other groups like Regression/Functional are commented out for flexibility.
-->
<suite name="Master Suite">

<!-- ================= -->
<!-- TestNG Listeners -->
<!-- ================= -->
    <!-- <listeners>
        <listener class-name="listeners.TestListener"/>
        <listener class-name="listeners.ExtentReportManager"/>
    </listeners> -->

<!-- ====================== -->
<!-- Group Execution Filter -->
<!-- ====================== -->
  <test name="grouping test">
    
     <groups>
		<run>
            <include name="Sanity"/>   <!-- Include tests marked as @Test(groups={"Sanity"}) -->
			<include name="Master"/>
            <!-- 🔽 Optional toggles: Uncomment as needed -->
            <!-- <include name="Regression"/> -->
            <!-- <exclude name="Sanity"/> -->
            <!-- <exclude name="Regression"/> -->
            <!-- <include name="Functional"/> -->
		</run>
	 </groups>

      <!-- ============================ -->
      <!-- Classes to be executed here -->
      <!-- ============================ -->
      <classes>
          <!--<class name="testGrouping.GP001LoginTest"/>-->
              <class name="testGrouping.GP002HomeTest"/>
        <!--  <class name="testGrouping.GP003BookingTest"/>
              <class name="testGrouping.GP004SearchingTest"/>
              <class name="testGrouping.GP005OverflowMenuTest"/>
              <class name="testGrouping.GP006DashboardTest"/>-->
      </classes>

</test> <!-- Test --> <!-- End of Grouping Test -->
  
</suite> <!-- Suite --> <!-- End of Master Suite -->