<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Mobile_Automation_Parallel_Suite"
       parallel="tests"
       thread-count="2"
       verbose="1">

    <!-- Listener is used to track test events: start, pass, fail  -->
    <listeners>
       <!-- <listener class-name="listeners.ExtentReportManager"></listener> -->
    </listeners>

    <!-- Device 1: Physical Device -->

    <test name="Physical Device - Redmi Note 12 Pro+">
        <!-- Parameters passed to the Appium Driver -->
        <parameter name="platformName"     value="Android"/>
