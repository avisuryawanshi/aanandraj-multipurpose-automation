         <parameter name="udid"             value="adb-cqrwkn89h6wocew8-pQXpCZ._adb-tls-connect._tcp"/>
         <parameter name="platformVersion"  value="14"/>
         <parameter name="automationName"   value="UiAutomator2"/> -->

     <classes>
         <class name="testGrouping.LoginTest"/>
     </classes>
 </test>

 <!-- Device 2: Pixel Emulator -->

    <test name="Emulator - Pixel 6 API 34">
