<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >

<!-- <suite name="Grouping Test Suite" parallel="false"> -->
    <suite name="Grouping Test Suite" >
    <!--<listeners>
        <listener class-name="listeners.ExtentTestListener"/>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>-->

    <test name="grouping test">

        <!-- Parameters passed to the Appium Driver -->
        <parameter name="platformName" value="Android"/>
        <parameter name="deviceName" value="sdk_gphone64_x86_64"/>
        <parameter name="udid" value="emulator-5554"/>
        <parameter name="platformVersion" value="14"/>
        <parameter name="automationName" value="UiAutomator2"/>

        <groups>
            <run>
                <include name="Sanity"/>   <!-- Include tests marked as @Test(groups={"Sanity"}) -->
                <include name="Master"/>
                <!-- 🔽 Optional toggles: Uncomment as needed -->
                <!-- <include name="Regression"/> -->
                <!-- <exclude name="Sanity"/> -->
                <!-- <exclude name="Regression"/> -->
                <!-- <include name="Functional"/> -->
            </run>
        </groups>

        <classes>
            <!-- 🔹 Individual Test Cases ===================================== -->
            <class name="testCases.M01_LoginTests"/>
            <class name="testCases.M02_HomeTests"/>
            <class name="testCases.M03_BookingWorkflowTests"/>
            <class name="testCases.M03_SearchingTests"/>
            <class name="testCases.M03_OverflowMenuTest"/>
            <class name="testCases.M03_DashboardTest"/>
            <class name="testCases.M01_BiometricTests"/>
            <class name="testCases.M01_LoginRandomTest"/>
            <!-- 🔸 Grouped Test Cases ======================================== -->
            <!--<class name="testGrouping.GP001LoginTest"/>
            <class name="testGrouping.GP002HomeTest"/>
            <class name="testGrouping.GP003BookingTest"/>
            <class name="testGrouping.GP004SearchingTest"/>
            <class name="testGrouping.GP005OverflowMenuTest"/>
            <class name="testGrouping.GP006DashboardTest"/> -->
        </classes>


    </test>

</suite>
