<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >

<suite name="Grouping Test Suite" parallel="false">

    <!--<listeners>
        <listener class-name="listeners.ExtentTestListener"/>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>-->

    <test name="grouping test">

        <groups>
            <run>
                <include name="Sanity"/>   <!-- Include tests marked as @Test(groups={"Sanity"}) -->
                <include name="Master"/>
                <!-- 🔽 Optional toggles: Uncomment as needed -->
                <!-- <include name="Regression"/> -->
                <!-- <exclude name="Sanity"/> -->
                <!-- <exclude name="Regression"/> -->
                <!-- <include name="Functional"/> -->
            </run>
        </groups>

        <classes>
            <!-- 🔹 Individual Test Cases ===================================== -->
            <class name="testCases.TC001LoginTest"/>
            <class name="testCases.TC002HomeTest"/>
            <class name="testCases.TC003BookingTest"/>
            <class name="testCases.TC004SearchingTest"/>
            <class name="testCases.TC005OverflowMenuTest"/>
            <class name="testCases.TC006DashboardTest"/>
            <class name="testCases.TC007LoginBiometricTest"/>
            <class name="testCases.TC008LoginRandomTest"/>
            <!-- 🔸 Grouped Test Cases ======================================== -->
            <class name="testGrouping.GP001LoginTest"/>
            <class name="testGrouping.GP002HomeTest"/>
            <class name="testGrouping.GP003BookingTest"/>
            <class name="testGrouping.GP004SearchingTest"/>
            <class name="testGrouping.GP005OverflowMenuTest"/>
            <class name="testGrouping.GP006DashboardTest"/>
        </classes>


    </test>

</suite>
